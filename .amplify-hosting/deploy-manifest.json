{
  "version": 1,
  "routes": [
    {
      "path": "/api/*",
      "target": {
        "kind": "compute",
        "src": "kp-backend"
      }
    },
    {
      "path": "/*",
      "target": {
        "kind": "static"
      },
      "fallback": "index.html"
    }
  ],
  "computeResources": [
    {
      "name": "kp-backend",
      "runtime": "nodejs20.x",
      "entrypoint": "kp-backend/index.js"
    }
  ]
}
